{
  "name": "datanode-social-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "static": "python3 -m http.server 4173",
    "agent:collector": "node agents/instagram-city-agent.js",
    "agent:threads": "node agents/threads-city-agent.js",
    "agent:enrich": "node agents/enrichment-agent.js",
    "agent:review": "node agents/review-candidates-agent.js",
    "agent:graph": "node agents/graph-builder-agent.js",
    "agent:investigation": "node agents/investigation-run-agent.js",
    "agent:run": "node agents/run-city-agents.js",
    "agent:login:instagram": "node agents/save-storage-state.js --platform=instagram",
    "agent:login:threads": "node agents/save-storage-state.js --platform=threads",
    "agent:smoke": "node agents/run-city-agents.js --dry-run --cities=hamilton --queries=3 --per-query=3 --concurrency=2 --recent-months=3",
    "agent:all:smoke": "node agents/run-city-agents.js --dry-run --platforms=instagram,threads --cities=hamilton --queries=3 --per-query=3 --concurrency=2 --recent-months=3",
    "agent:threads:smoke": "node agents/threads-city-agent.js --dry-run --cities=hamilton --queries=3 --per-query=3 --concurrency=2 --recent-months=3",
    "agent:hamilton": "node agents/run-city-agents.js --platforms=instagram,threads --cities=hamilton --queries=3 --per-query=3 --concurrency=1 --recent-months=3"
  },
  "devDependencies": {
    "playwright": "1.54.0"
  }
}
