{
  "name": "datanode-social-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 4173",
    "start": "python3 -m http.server 4173",
    "agent:collector": "node agents/instagram-city-agent.js",
    "agent:enrich": "node agents/enrichment-agent.js",
    "agent:graph": "node agents/graph-builder-agent.js",
    "agent:run": "node agents/run-city-agents.js",
    "agent:smoke": "node agents/run-city-agents.js --dry-run --cities=toronto,vancouver --topics=food,rent-real-estate --concurrency=2"
  },
  "devDependencies": {
    "playwright": "1.54.0"
  }
}
